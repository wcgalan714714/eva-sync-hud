# Oura OAuth (register at https://cloud.ouraring.com/oauth/applications)
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
OURA_REDIRECT_URI=http://localhost:3000/api/oura/callback

# Fastest path when ring arrives — Personal Access Token from Oura developer portal
OURA_PERSONAL_ACCESS_TOKEN=

# Optional: session hardening for production
# SESSION_SECRET=